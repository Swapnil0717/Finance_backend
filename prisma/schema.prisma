generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VIEWER
  ANALYST
  ADMIN
}

enum RecordType {
  INCOME
  EXPENSE
}

enum TokenType {
  REFRESH
  VERIFY_EMAIL
  RESET_PASSWORD
}

model User {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  password        String?
  role            Role     @default(VIEWER)
  isActive        Boolean  @default(true)
  isEmailVerified Boolean  @default(false)

  provider        String?
  providerId      String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  records         FinancialRecord[]
  tokens          Token[]

  // Analyst Assignment Relations
  assignedUsers   AnalystAssignment[] @relation("AnalystAssignments")
  assignedAnalyst AnalystAssignment[] @relation("UserAssignments")

  @@index([email])
}

model FinancialRecord {
  id          String      @id @default(uuid())
  amount      Decimal     @db.Decimal(12, 2)
  type        RecordType
  category    String
  note        String?
  date        DateTime

  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])

  isDeleted   Boolean     @default(false)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([createdById])
  @@index([type])
  @@index([category])
  @@index([date])
}

model AnalystAssignment {
  id         String @id @default(uuid())

  analystId  String
  userId     String

  analyst    User   @relation("AnalystAssignments", fields: [analystId], references: [id])
  user       User   @relation("UserAssignments", fields: [userId], references: [id])

  createdAt  DateTime @default(now())

  @@unique([analystId, userId])
}

model Token {
  id        String    @id @default(uuid())
  token     String    @unique
  type      TokenType

  userId    String
  user      User      @relation(fields: [userId], references: [id])

  expiresAt DateTime
  isRevoked Boolean   @default(false)

  createdAt DateTime  @default(now())

  @@index([userId])
}